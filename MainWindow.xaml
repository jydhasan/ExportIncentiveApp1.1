<Window x:Class="ExportIncentiveApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Incentive PDF Generator"

        Width="1050"
        Height="680"

        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowState="Normal"

        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
        MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"

        Background="#F5F6FA"
        Icon="app.ico">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#95A5A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GroupStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="#DDE1E7"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#DDE1E7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50">
            <TextBlock Text="Export Incentive PDF Generator" 
                       FontSize="22" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- File Upload -->
                <GroupBox Header="📁  Excel File Upload" Style="{StaticResource GroupStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="#DDE1E7" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,10,0">
                            <TextBlock x:Name="FilePathLabel" Text="No file selected" 
                                       Foreground="#7F8C8D" VerticalAlignment="Center"/>
                        </Border>
                        <Button Grid.Column="1" Content="Browse Excel File" 
                                Style="{StaticResource PrimaryButton}"
                                Click="BrowseFile_Click"/>
                    </Grid>
                </GroupBox>

                <!-- Contract Table -->
                <GroupBox Header="📋  Contract Details (Editable)" Style="{StaticResource GroupStyle}">
                    <DataGrid x:Name="ContractTable" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MinHeight="120" MaxHeight="250"
                              GridLinesVisibility="All"
                              BorderBrush="#DDE1E7" BorderThickness="1"
                              RowBackground="White" AlternatingRowBackground="#F8F9FA"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sheet Name" Binding="{Binding SheetName}" IsReadOnly="True" Width="120"/>
                            <DataGridTextColumn Header="Company Name" Binding="{Binding CompanyName}" IsReadOnly="True" Width="200"/>
                            <DataGridTextColumn Header="Contract No. (from Excel)" Binding="{Binding ContractNumber}" IsReadOnly="True" Width="160"/>
                            <DataGridTextColumn Header="Contract Date (from Excel)" Binding="{Binding ContractDate}" IsReadOnly="True" Width="150"/>
                            <DataGridTextColumn Header="Contract Value USD (from Excel)" Binding="{Binding ContractValue}" IsReadOnly="True" Width="180"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- General Info -->
                <GroupBox Header="⚙️  General Information" Style="{StaticResource GroupStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Company Address:" VerticalAlignment="Center"/>
                            <TextBox x:Name="CompanyAddressInput" Grid.Column="1" 
                                     Text="66, Hajipara, Dhaka"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Bank Branch:" VerticalAlignment="Center"/>
                            <TextBox x:Name="BankBranchInput" Grid.Column="1" 
                                     Text="Local Office, Dhaka"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Audit Fee Note:" VerticalAlignment="Top" Margin="0,6,0,0"/>
                            <TextBox x:Name="AuditFeeNoteInput" Grid.Column="1" 
                                     TextWrapping="Wrap" AcceptsReturn="True" Height="70"
                                     Text="Audit fee calculated in accordance with Bangladesh Bank FE circular letter No. FEPD (Com)291/2002-1367 dated 2 June 2002"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Info Box -->
                <Border Background="#EAF4FB" BorderBrush="#3498DB" BorderThickness="0,0,0,4" 
                        CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,6">
                            Audit Fee Calculation Basis:
                        </TextBlock>
                        <TextBlock Foreground="#555" FontSize="12" LineHeight="22">
                            • 0 – 5,00,000 BDT → 4,000 Taka per contract&#x0a;• 5,00,001 – 10,00,000 BDT → 5,000 Taka per contract&#x0a;• 10,00,001 and above → 7,000 Taka per contract&#x0a;&#x0a;Note: Each sheet = one contract. Application Date and Financial Years are auto-extracted from Excel.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Progress Bar -->
                <ProgressBar x:Name="ProgressBar" Height="10" Margin="0,0,0,12" 
                             Visibility="Collapsed" Minimum="0" Maximum="100"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="GenerateBtn" Content="⬇  Generate PDF Documents"
                            Style="{StaticResource GreenButton}"
                            FontSize="14" Padding="20,12"
                            Margin="0,0,14,0"
                            IsEnabled="False"
                            Click="GeneratePDFs_Click"/>
                    <Button Content="📥  Download Excel Template"
                            Style="{StaticResource PrimaryButton}"
                            FontSize="14" Padding="20,12"
                            Click="DownloadTemplate_Click"/>
                </StackPanel>

                <TextBlock x:Name="StatusLabel" Text="" HorizontalAlignment="Center" 
                           Margin="0,12,0,0" FontSize="13" Foreground="#27AE60"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

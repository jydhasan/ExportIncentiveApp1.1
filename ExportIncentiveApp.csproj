<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ExportIncentiveApp</AssemblyName>
    <RootNamespace>ExportIncentiveApp</RootNamespace>
    <PlatformTarget>x64</PlatformTarget>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <AssemblyTitle>Export Incentive PDF Generator</AssemblyTitle>
    <Company>Mahamud Sabuj &amp; Co.</Company>
    <Product>Export Incentive PDF Generator</Product>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.102.3" />
    <PackageReference Include="DinkToPdf" Version="1.0.8" />
  </ItemGroup>

  <!-- Icon as resource -->
  <ItemGroup>
    <Resource Include="app.ico" />
  </ItemGroup>

  <!-- libwkhtmltox.dll must sit next to the EXE -->
  <ItemGroup>
    <None Update="libwkhtmltox.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
